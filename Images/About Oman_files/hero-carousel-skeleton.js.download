(function () {
    function initHeroCarouselSkeleton() {
        var placeholder = document.querySelector('.hero-carousel-placeholder');
        var carousel = document.querySelector('.hero-carousel-target');

        if (!placeholder || !carousel) {
            return;
        }

        var hasHidden = false;
        var isReady = false;

        function doHide() {
            if (hasHidden) {
                return;
            }
            hasHidden = true;

            try {
                var activeSlide = carousel.querySelector('.carousel-item.active');
                if (activeSlide) {
                    var videos = activeSlide.querySelectorAll('video');
                    videos.forEach(function (video) {
                        try {
                            video.currentTime = 0;
                            if (typeof video.play === 'function') {
                                var playPromise = video.play();
                                if (playPromise && typeof playPromise.catch === 'function') {
                                    playPromise.catch(function () { });
                                }
                            }
                        } catch (e) {
                        }
                    });

                    var iframes = activeSlide.querySelectorAll('iframe');
                    iframes.forEach(function (frame) {
                        try {
                            var src = frame.getAttribute('src');
                            if (src) {
                                frame.setAttribute('src', src);
                            }
                        } catch (e) {
                        }
                    });
                }
            } catch (e) {
              
            }

            placeholder.classList.add('d-none');
        }

        function tryHide() {
            if (hasHidden) {
                return;
            }
            if (!isReady) {
                return;
            }
            doHide();
        }

        var mediaElements = carousel.querySelectorAll(
            '.carousel-item.active img, .carousel-item.active video, .carousel-item.active iframe'
        );

        var remaining = mediaElements.length;

        function markReady() {
            if (isReady) {
                return;
            }
            isReady = true;
            tryHide();
        }

        function onMediaLoaded() {
            if (remaining <= 0) {
                return;
            }
            remaining--;
            if (remaining <= 0) {
                markReady();
            }
        }

        if (!mediaElements.length) {
            markReady();
        } else {
            mediaElements.forEach(function (el) {
                if (!el || !el.tagName) {
                    onMediaLoaded();
                    return;
                }

                var tag = el.tagName.toUpperCase();

                if (tag === 'IMG') {
                    if (el.complete) {
                        onMediaLoaded();
                    } else {
                        el.addEventListener('load', onMediaLoaded, { once: true });
                        el.addEventListener('error', onMediaLoaded, { once: true });
                    }
                } else if (tag === 'VIDEO') {
                    if (el.readyState >= 2) {
                        onMediaLoaded();
                    } else {
                        el.addEventListener('loadeddata', onMediaLoaded, { once: true });
                        el.addEventListener('error', onMediaLoaded, { once: true });
                    }
                } else if (tag === 'IFRAME') {
                    var iframeLoaded = false;
                    function iframeDone() {
                        if (iframeLoaded) {
                            return;
                        }
                        iframeLoaded = true;
                        onMediaLoaded();
                    }
                    el.addEventListener('load', iframeDone, { once: true });
                    el.addEventListener('error', iframeDone, { once: true });
                    setTimeout(iframeDone, 4000);
                } else {
                    onMediaLoaded();
                }
            });
        }

        // remove anyway after 20 seconds
        setTimeout(function () {
            if (!hasHidden) {
                doHide();
            }
        }, 120000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHeroCarouselSkeleton);
    } else {
        initHeroCarouselSkeleton();
    }
})();
